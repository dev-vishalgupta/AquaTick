{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AquaTick",
  "version": "0.1.0",
  "identifier": "com.aquatick.app",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "AquaTick",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 600,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "pnpm run frontend:dev",
    "beforeBuildCommand": "pnpm run frontend:build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "plugins": {}
}
